# LingProxy 配置文件示例
# 复制此文件为 config.yaml 并根据实际情况修改配置

app:
  name: "LingProxy"
  version: "1.0.0"
  environment: "development"  # development, staging, production
  port: 8080
  host: "0.0.0.0"

storage:
  type: "gorm"  # memory 或 gorm
  gorm:
    driver: "sqlite"  # sqlite, mysql, postgres
    dsn: "lingproxy.db"
    # MySQL 示例（请修改为实际值）
    # driver: "mysql"
    # dsn: "username:password@tcp(localhost:3306)/lingproxy?charset=utf8mb4&parseTime=True&loc=Local"
    # PostgreSQL 示例（请修改为实际值）
    # driver: "postgres"
    # dsn: "host=localhost user=username password=password dbname=lingproxy port=5432 sslmode=disable TimeZone=Asia/Shanghai"

log:
  level: "info"  # debug, info, warn, error, fatal
  format: "json"  # text, json
  output: "stdout"  # stdout, file

security:
  auth:
    enabled: true  # 是否启用认证，false时所有API（除登录外）都不需要认证
  cors:
    enabled: true
    allow_origins:
      - "*"
    allow_methods:
      - "GET"
      - "POST"
      - "PUT"
      - "DELETE"
      - "OPTIONS"
    allow_headers:
      - "*"

load_balancer:
  default_strategy: "round_robin"

provider:
  timeout: "30s"
  max_retries: 3

admin:
  username: "admin"
  # ⚠️ 请设置强密码！首次启动后建议立即修改
  # password: "YOUR_STRONG_PASSWORD_HERE"
  password: ""  # 留空则不会设置密码，需要通过其他方式设置
  api_key: ""  # 留空则自动生成，首次启动后查看日志获取
  auto_create: true
